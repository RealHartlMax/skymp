{
  "compilerOptions": {
    "noImplicitAny": true,
    "allowJs": true,
    "module": "Node16",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2022",
    "moduleResolution": "node16",
    "sourceMap": true,
    "rootDir": "ts",
    "outDir": "../build/dist/server/dist_back",
    "skipLibCheck": true
  },
  "include": ["ts"]
}
