{
  "verbose": true,
  "ignoreDeprecations": "6.0",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "es2020",
    "module": "nodenext",
    "strict": true,
    "alwaysStrict": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "lib": ["esnext"],
    "paths": { "skyrimPlatform": ["node_modules/@skyrim-platform/skyrim-platform"] },
    "rootDir": "src",
    "outDir": "dist"
  },
  "include": ["src/**/*.ts"]
}
